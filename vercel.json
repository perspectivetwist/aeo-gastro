{
  "redirects": [
    {
      "source": "/",
      "destination": "https://www.ki-gastronomie.com/aeo-scanner/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
